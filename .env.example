# Authskye Environment Variables
# Copy this file to .env.local and fill in your values

# ===========================================
# VPN/Corporate Proxy (Optional)
# ===========================================

# If behind corporate proxy with TLS interception, trust the CA cert
# NODE_EXTRA_CA_CERTS='/path/to/corporate_certificates.pem'

# ===========================================
# AUTH0 - Core SDK Configuration
# ===========================================

# Generate with: openssl rand -hex 32
AUTH0_SECRET=''

# Your application URL (ngrok for local dev, production URL for deployment)
# AUTH0_BASE_URL='http://localhost:4020'
AUTH0_BASE_URL='https://your-domain.ngrok-free.app'

# Your Auth0 tenant domain (canonical or custom domain)
# Use canonical domain (your-tenant.us.auth0.com) for most setups
# Use custom domain (login.yourdomain.com) if configured
AUTH0_ISSUER_BASE_URL='https://your-tenant.us.auth0.com'

# Regular Web Application credentials
AUTH0_CLIENT_ID=''
AUTH0_CLIENT_SECRET=''

# Database connection ID for organization invitations
AUTH0_CONNECTION_ID='Username-Password-Authentication'

# Optional: Organization-specific client ID (if main client doesn't support org invitations)
# AUTH0_ORG_CLIENT_ID=''

# API Identifier (audience)
AUTH0_AUDIENCE='https://your-api.example.com'

# OAuth scopes to request
# Note: My Account API scopes are NOT needed here - token exchange handles that
AUTH0_SCOPE='openid profile email offline_access'

# Namespace for custom claims in JWT tokens (must match Auth0 Action)
# Used for roles, org_id, org_name, org_logo, session_id claims
NEXT_PUBLIC_AUTH0_NAMESPACE='https://authskye.com'

# My Account API audience (for MFA management via My Account API)
# Format: https://{your-auth0-domain}/me/
NEXT_PUBLIC_MY_ACCOUNT_AUDIENCE='https://your-tenant.us.auth0.com/me/'

# ===========================================
# AUTH0 - Management API (M2M Application)
# ===========================================

# Always use the canonical Auth0 domain (not custom domain)
AUTH0_MGMT_DOMAIN='your-tenant.us.auth0.com'

# M2M Application credentials (for Management API calls)
AUTH0_MGMT_CLIENT_ID=''
AUTH0_MGMT_CLIENT_SECRET=''

# Optional: Claude M2M Client (full tenant access for AI assistance)
# AUTH0_CLAUDE_CLIENT_ID=''
# AUTH0_CLAUDE_CLIENT_SECRET=''

# ===========================================
# FIREBASE - Firestore Database
# ===========================================

# Base64-encoded service account JSON
# Generate with: base64 -i path/to/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=''

# ===========================================
# AUTH0 FGA - Fine-Grained Authorization
# ===========================================

# FGA API endpoint (US region)
FGA_API_URL='https://api.us1.fga.dev'

# FGA Store ID (from dashboard.fga.dev)
FGA_STORE_ID=''

# Optional: Authorization Model ID (leave empty to use latest)
FGA_MODEL_ID=''

# FGA Client credentials (from dashboard.fga.dev)
FGA_CLIENT_ID=''
FGA_CLIENT_SECRET=''

# Token issuer and audience for FGA API
# Use auth.fga.dev for production FGA stores
FGA_API_TOKEN_ISSUER='auth.fga.dev'
FGA_API_AUDIENCE='https://api.us1.fga.dev/'

# ===========================================
# KONG API GATEWAY (Optional)
# ===========================================

# Kong Konnect Gateway URL
# Requires Kong Konnect subscription
NEXT_PUBLIC_KONG_GATEWAY_URL=''

# ===========================================
# CUSTOM TOKEN EXCHANGE (CTE) - My Account API
# ===========================================

# CTE M2M Application credentials (for token exchange)
# Used to exchange session token for My Account API token
CTE_CLIENT_ID=''
CTE_CLIENT_SECRET=''

# Enabled MFA Factors (comma-separated)
# Options: sms, totp, email, passkey
# Note: passkey is the correct type for cross-device/platform credentials
# Note: push-notification requires Auth0 Guardian app
NEXT_PUBLIC_ENABLED_MFA_FACTORS='sms,totp,email,passkey'

# ===========================================
# AI AGENTS - LLM Configuration (Optional)
# ===========================================

# Option 1: LightLLM (Okta internal)
# Used for the Agents demo chatbot
LIGHTLLM_ENDPOINT=''
LIGHTLLM_API_KEY=''
LIGHTLLM_MODEL='gpt-4o'

# Option 2: OpenAI (alternative)
# OPENAI_API_KEY=''
# OPENAI_MODEL='gpt-4o'
